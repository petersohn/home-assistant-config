#!/usr/bin/env bash

set -e

script_dir=$(readlink -e "$(dirname "$0")")
root_dir=$(readlink -e "${script_dir}/../..")
cd "$script_dir"

export PYTHONPATH="${script_dir}:${root_dir}/robotframework-httplibrary/src:${PYTHONPATH}"
export TZ=Europe/Budapest

output_dir="${PWD}/output"
mkdir -p "${output_dir}"
default_robot_python="${script_dir}/../.venv/bin/python"
[ -x "${default_robot_python}" ] || default_robot_python="python"
exec "${ROBOT_PYTHON:-${default_robot_python}}" -m robot --outputdir="${output_dir}" --variable "base_output_directory:${output_dir}" "$@" .
