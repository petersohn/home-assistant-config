{
    "debug": true,
    "name": "gate_controller",
    "availabilityTopic": "home/devices/gate_controller/available",
    "statusTopic": "home/devices/gate_controller/status",
    "debugTopic": "home/devices/gate_controller/debug",
    "interfaces": [
        {
            "type": "cover",
            "name": "gate",
            "commandTopic": "home/gate/main/set",
            "upPin": 0,
            "downPin": 2,
            "upMovementPin": 3,
            "downMovementPin": 4,
            "stopPin": 16,
            "invertInput": false,
            "invertOutput": true,
            "closedPosition": 5,
            "positionSensors": [
                {
                    "position": 0,
                    "pin": 13,
                    "invert": true
                },
                {
                    "position": 40,
                    "pin": 12,
                    "invert": true
                },
                {
                    "position": 100,
                    "pin": 5,
                    "invert": true
                }
            ]
        }
    ],
    "actions": [
        {
            "type": "publish",
            "interface": "gate",
            "topic": "home/gate/main/position",
            "template": "%2",
            "retain": true
        },
        {
            "type": "publish",
            "interface": "gate",
            "topic": "home/gate/main/state",
            "template": "%1",
            "retain": true
        }
    ]
}
